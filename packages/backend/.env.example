# Sunucu Ayarları
PORT=3001
NODE_ENV=development

# Veritabanı
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cognitive_agent?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Gemini API
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini Model Ayarları
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
LIVE_VOICE_NAME=Puck

# Görsel Üretim - Ayrı API Key (kota ayrımı için, opsiyonel)
# Ayarlanmazsa GOOGLE_API_KEY kullanılır
GEMINI_IMAGE_API_KEY=your-image-api-key-here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
